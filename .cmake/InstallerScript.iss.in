; Script generated by the Inno Setup Script Wizard.
; SEE THE DOCUMENTATION FOR DETAILS ON CREATING INNO SETUP SCRIPT FILES!

#define MyAppName "BookCanvas"
#define MyAppVersion "${PROJECT_VERSION}"
#define MyAppPublisher "kingpoem"
#define MyAppURL "https://github.com/kingpoem"
#define MyAppExeName "bookcanvas.exe"
#define MyAppFileDir "dist"

[Setup]
; NOTE: The value of AppId uniquely identifies this application. Do not use the same AppId value in installers for other applications.
; (To generate a new GUID, click Tools | Generate GUID inside the IDE.)
AppId={{F1207DE5-600E-46C1-BE43-20531CD45288}
AppName={#MyAppName}
AppVersion={#MyAppVersion}
;AppVerName={#MyAppName} {#MyAppVersion}
AppPublisher={#MyAppPublisher}
AppPublisherURL={#MyAppURL}
AppSupportURL={#MyAppURL}
AppUpdatesURL={#MyAppURL}
DefaultDirName={autopf}\BookCanvas
UninstallDisplayIcon={app}\{#MyAppExeName}
; "ArchitecturesInstallIn64BitMode=x64compatible" requests that the
; install be done in "64-bit mode" on x64 or Windows 11 on Arm,
; meaning it should use the native 64-bit Program Files directory and
; the 64-bit view of the registry.
ChangesAssociations=yes
DefaultGroupName={#MyAppName}
AllowNoIcons=yes
LicenseFile=.\..\LICENSE
; Uncomment the following line to run in non administrative install mode (install for current user only).
;PrivilegesRequired=lowest
OutputDir=.\
OutputBaseFilename=BookCanvas-{#MyAppVersion}-Setup
SetupIconFile=.\..\res\icon\app.ico
SolidCompression=yes
WizardStyle=modern

[Languages]
Name: "english"; MessagesFile: "compiler:Default.isl"

[Tasks]
Name: "desktopicon"; Description: "{cm:CreateDesktopIcon}"; GroupDescription: "{cm:AdditionalIcons}"; Flags: unchecked

[Files]
Source: ".\..\{#MyAppFileDir}\{#MyAppExeName}"; DestDir: "{app}"; Flags: ignoreversion
Source: ".\..\{#MyAppFileDir}\*"; DestDir: "{app}"; Flags: ignoreversion recursesubdirs createallsubdirs
; NOTE: Don't use "Flags: ignoreversion" on any shared system files

[Icons]
Name: "{group}\{#MyAppName}"; Filename: "{app}\{#MyAppExeName}"
Name: "{group}\{cm:UninstallProgram,{#MyAppName}}"; Filename: "{uninstallexe}"
Name: "{autodesktop}\{#MyAppName}"; Filename: "{app}\{#MyAppExeName}"; Tasks: desktopicon

[Run]
Filename: "{app}\{#MyAppExeName}"; Description: "{cm:LaunchProgram,{#StringChange(MyAppName, '&', '&&')}}"; Flags: nowait postinstall skipifsilent

[Code]
var
  SelectDirAdminHint: TNewStaticText;

procedure InitializeWizard;
begin
  { 在安装目录页显示红色提示，避免默认 Program Files 导致应用无法写入导出文件 }
  SelectDirAdminHint := TNewStaticText.Create(WizardForm);
  { 部分 Inno 版本无 SelectDirPage.Surface，使用路径框父面板作为容器 }
  SelectDirAdminHint.Parent := WizardForm.DirEdit.Parent;
  SelectDirAdminHint.Caption :=
    'Recommendation: Do not install under "Program Files" or other protected locations where ' +
    'normal users cannot write, or BookCanvas may fail when exporting topology and JSON config files.';
  SelectDirAdminHint.AutoSize := True;
  SelectDirAdminHint.WordWrap := True;
  SelectDirAdminHint.Font.Color := clRed;
  SelectDirAdminHint.Left := WizardForm.DirEdit.Left;
  SelectDirAdminHint.Top := WizardForm.DirEdit.Top + WizardForm.DirEdit.Height + ScaleY(10);
  SelectDirAdminHint.Width := WizardForm.DirEdit.Parent.ClientWidth - SelectDirAdminHint.Left - ScaleX(12);
end;
